---
/**
 * ΉΕεΈ╣ΕΉΛν ΈηεΈΦσ ΊΟαΉζ┤ΉπΑ (ΉιΧΉιΒ). landingPageDefinitionsΈκε getStaticPaths ΉΔζΉΕ▒ΊΧαΆ│ι
 * Ή╜αΊΖΡΉ╕ι overrideΈξ╝ Έ╣ΝΈΥε ΊΔΑΉηΕΉΩΡ SupabaseΉΩΡΉΕε ΊΧ┤ΉΕζΊΧεΈΜν(ΉΩΗΉε╝Έσ┤ Ά╕░Έ│╕Ά░Τ έΑΦ Ά│ΕΊγΞ D-3a).
 * summary/points/faq/relatedLinksΈΛΦ ΉιΧΉιΒ HTML, blog ΉΕ╣ΉΖαΈπΝ client:visible ΉΧΕΉζ╝ΈηεΈΥε.
 */
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import Seo from "../../components/seo/Seo.astro";
import { SiteHeaderIsland } from "../../components/site/SiteHeaderIsland";
import { MobileQuickCta } from "../../components/site/SiteFooter";
import {
  LandingSummarySection,
  LandingPointsSection,
  LandingFaqSection,
  LandingRelatedSection
} from "../../components/landing/LandingSections";
import { LandingBlogSection, LandingBackButton } from "../../components/landing/LandingInteractive";
import { landingPageDefinitions, mergeLandingPageContent, buildLandingPageJsonLd } from "../../landingPages";
import { defaultLandingSectionOrder } from "../../contentSections";
import { SiteContentService } from "../../services/SiteContentService";

export async function getStaticPaths() {
  // A build-time Supabase failure must not fail the whole Astro build; fall back
  // to defaults (empty overrides) so pages still prerender.
  const overrides = await new SiteContentService()
    .loadLandingPagesContent()
    .catch(() => ({}) as Awaited<ReturnType<SiteContentService["loadLandingPagesContent"]>>);
  return landingPageDefinitions
    .filter((def) => def.categoryLabel === "ΉΕεΈ╣ΕΉΛν" && def.path.startsWith("/service/"))
    .map((def) => ({
      params: { slug: def.path.replace("/service/", "") },
      props: { merged: mergeLandingPageContent(def, overrides[def.path]) }
    }));
}

const { merged } = Astro.props;
const siteUrl = "https://www.jipsuriclass.kr";
const jsonLd = buildLandingPageJsonLd(merged, siteUrl);
const sections = merged.sections ?? defaultLandingSectionOrder;
---
<BaseLayout>
  <Seo slot="head" title={merged.title} description={merged.description} path={merged.path} jsonLd={jsonLd} />
  <SiteHeaderIsland client:idle brandHref="/" />
  <LandingBackButton client:idle fallbackHref="/" />
  <main class="landing-page" id="top">
    {
      sections.map((sectionId) => {
        if (sectionId === "summary") return <LandingSummarySection content={merged} />;
        if (sectionId === "points") return <LandingPointsSection content={merged} />;
        if (sectionId === "blog") return <LandingBlogSection client:visible content={merged} />;
        if (sectionId === "faq") return <LandingFaqSection content={merged} />;
        if (sectionId === "relatedLinks") return <LandingRelatedSection content={merged} />;
        return null;
      })
    }
  </main>
  <MobileQuickCta />
</BaseLayout>
