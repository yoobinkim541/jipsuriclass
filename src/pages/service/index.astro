---
/**
 * 서비스 허브(/service) — 정적 Astro 목록 페이지.
 * 기존엔 [...all].astro 의 client:only SPA 라 정적 HTML이 비어 크롤 분배가 안 됐다.
 * landingPageDefinitions 로 모든 서비스를 서버렌더 + 링크해 색인/크롤 경로를 만든다.
 */
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import Seo from "../../components/seo/Seo.astro";
import { SiteHeaderIsland } from "../../components/site/SiteHeaderIsland";
import { MobileQuickCta } from "../../components/site/SiteFooter";
import { landingPageDefinitions } from "../../landingPages";
import { servicePricingRegistry } from "../../pricing/registry";

const services = landingPageDefinitions.filter(
  (def) => def.categoryLabel === "서비스" && def.path.startsWith("/service/")
);

const title = "집수리 서비스 전체 | 집수리클라쓰";
const description =
  "누수, 욕실, 도배, 전기, 목공, 방수, 타일 등 집수리클라쓰가 제공하는 모든 집수리 서비스를 한곳에서 확인하고 기준 단가까지 안내받으세요.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    url: "https://www.jipsuriclass.kr/service",
    description
  }
];
---
<BaseLayout>
  <Seo slot="head" title={title} description={description} path="/service" jsonLd={jsonLd} />
  <SiteHeaderIsland client:idle brandHref="/" />
  <main class="hub-page" id="top">
    <header class="hub-page__head">
      <h1>집수리 서비스</h1>
      <p>사진 상담으로 시작하는 생활 집수리부터 전체 리모델링까지. 필요한 서비스를 골라 자세한 안내와 기준 단가를 확인하세요.</p>
    </header>
    <ul class="hub-grid">
      {
        services.map((service) => (
          <li class="hub-card">
            <h2><a href={service.path}>{service.serviceType ?? service.heroTitle}</a></h2>
            <p>{service.description}</p>
            <div class="hub-card__links">
              <a href={service.path}>자세히 보기</a>
              {servicePricingRegistry[service.path] && <a href={`${service.path}/pricing`}>기준 단가</a>}
            </div>
          </li>
        ))
      }
    </ul>
  </main>
  <MobileQuickCta />
</BaseLayout>

<style>
  .hub-page { max-width: 1100px; margin: 0 auto; padding: clamp(40px, 6vw, 88px) clamp(18px, 5vw, 48px); }
  .hub-page__head { margin-bottom: clamp(28px, 4vw, 48px); }
  .hub-page__head h1 { font-family: var(--f-display, sans-serif); font-weight: 800; font-size: clamp(28px, 4vw, 44px); letter-spacing: -0.02em; margin: 0 0 12px; color: var(--ink, #0b1a30); }
  .hub-page__head p { font-size: clamp(15px, 1.4vw, 17px); color: var(--ink-2, #2a3a55); margin: 0; line-height: 1.6; max-width: 640px; }
  .hub-grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .hub-card { border: 1px solid var(--hair, #e6dfd0); border-radius: 14px; padding: 22px; background: var(--cream, #faf7f2); }
  .hub-card h2 { font-size: 18px; font-weight: 700; margin: 0 0 8px; line-height: 1.3; }
  .hub-card h2 a { color: var(--ink, #0b1a30); text-decoration: none; }
  .hub-card h2 a:hover { color: var(--gold-600, #c49a38); }
  .hub-card p { font-size: 14px; color: var(--ink-2, #2a3a55); margin: 0 0 14px; line-height: 1.55; }
  .hub-card__links { display: flex; gap: 18px; }
  .hub-card__links a { font-size: 13px; font-weight: 600; color: var(--navy-700, #10284a); text-decoration: none; }
  .hub-card__links a:hover { text-decoration: underline; }
</style>
