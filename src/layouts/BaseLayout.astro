---
/**
 * BaseLayout.astro — index.html의 문서 셸을 이식한 공통 레이아웃.
 * 고정 head(폰트·아이콘·manifest·고정 OG)만 렌더하고, 페이지별 SEO 태그는
 * <slot name="head"> 로 받는다(보통 Seo.astro). styles.css는 단일 글로벌 import.
 * 서비스워커 등록은 main.tsx에서 이 곳으로 이전(PWA 유지, 계획 D-6).
 */
import "../styles.css";
// Self-host fonts (no Google Fonts CDN). Pretendard 가변폰트(동적 서브셋)를
// 본문·제목 공통으로 사용 — 라틴+한글 한 번에 커버. 숫자/모노는 JetBrains Mono.
import "pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import { landingPageDefinitions } from "../landingPages";
import { servicePricingRegistry } from "../pricing/registry";
import { business } from "../data";

// SEO: 정적(서버렌더) 내부 링크 디렉터리 — client:only SPA 라 홈/허브에 크롤 가능한
// 링크가 없어 발생하던 "발견됨-미색인"을 해소한다. 모든 페이지 정적 HTML에 노출된다.
const directoryServices = landingPageDefinitions.filter((page) => page.pageType === "Service");
const directoryAreas = landingPageDefinitions.filter((page) => page.pageType === "Place");
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#10284a" />
    <!-- 테마 무플래시 초기화: 저장된 선택(light|dark)이 없으면 시스템 설정을 따른다. -->
    <script is:inline>
      (function () {
        try {
          var v = localStorage.getItem("jsc-theme");
          var t =
            v === "light" || v === "dark"
              ? v
              : window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.dataset.theme = t;
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute("content", t === "dark" ? "#0b1220" : "#10284a");
        } catch (e) {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="집수리클라쓰" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/png" href="/icons/icon.png" />
    <link rel="apple-touch-icon" href="/icons/icon.png" />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <footer class="site-footer" aria-label="사이트 푸터">
      <div class="site-footer__inner">
        <nav class="site-footer__directory" aria-label="전체 페이지">
          <section>
            <h2>집수리 서비스</h2>
            <ul>
              {directoryServices.map((page) => (
                <li>
                  <a href={page.path}>{page.serviceType ?? page.path}</a>
                  {servicePricingRegistry[page.path] && <Fragment> · <a href={`${page.path}/pricing`}>가격표</a></Fragment>}
                </li>
              ))}
            </ul>
          </section>
          <section>
            <h2>지역별 집수리</h2>
            <ul>
              {directoryAreas.map((page) => (
                <li><a href={page.path}>{page.areaLabel} 집수리</a></li>
              ))}
            </ul>
          </section>
          <section>
            <h2>바로가기</h2>
            <ul>
              <li><a href="/">홈</a></li>
              <li><a href="/service">서비스 전체</a></li>
              <li><a href="/area">지역 전체</a></li>
              <li><a href="/portfolio">현장 사례</a></li>
              <li><a href="/estimate">간편 견적</a></li>
              <li><a href="/diagnosis">증상 자가진단</a></li>
            </ul>
          </section>
        </nav>
        <div class="site-footer__brand">
          <strong>{business.name}</strong>
          <p class="site-footer__biz">{business.registrationNumber} · {business.owner} · {business.address}</p>
          <p class="site-footer__note">개인정보는 상담 목적 외 사용하지 않으며, 아래 정책 페이지에서 처리 방침을 확인할 수 있습니다.</p>
          <div class="site-footer__policy">
            <a href="/portfolio">현장사례 모아보기</a>
            <a href="/privacy">개인정보처리방침</a>
          </div>
        </div>
      </div>
    </footer>
    <style>
      /* 고정 다크 네이비 — 라이트/다크 모드 공통(변수-플립 버그 없음). */
      .site-footer { background: #0e2240; color: rgba(255, 255, 255, 0.72); }
      .site-footer__inner { max-width: 1320px; margin: 0 auto; padding: clamp(36px, 5vw, 56px) clamp(18px, 5vw, 64px) clamp(40px, 6vw, 80px); display: flex; flex-direction: column; gap: 30px; }
      .site-footer__directory { display: grid; gap: 24px 32px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
      .site-footer__directory h2 { font-size: 13px; font-weight: 700; margin: 0 0 12px; color: #ffffff; }
      .site-footer__directory ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 7px; }
      .site-footer__directory a { color: rgba(255, 255, 255, 0.72); text-decoration: none; font-size: 13px; line-height: 1.5; }
      .site-footer__directory a:hover { color: var(--gold-500, #f2c879); text-decoration: underline; }
      .site-footer__brand { border-top: 1px solid rgba(255, 255, 255, 0.14); padding-top: 24px; display: flex; flex-direction: column; gap: 8px; }
      .site-footer__brand strong { color: #ffffff; font-size: 15px; }
      .site-footer__biz, .site-footer__note { margin: 0; font-size: 13px; color: rgba(255, 255, 255, 0.6); line-height: 1.6; }
      .site-footer__policy { display: flex; flex-wrap: wrap; gap: 8px 22px; margin-top: 8px; }
      .site-footer__policy a { color: var(--gold-500, #f2c879); font-size: 13px; font-weight: 600; text-decoration: none; }
      .site-footer__policy a:hover { text-decoration: underline; }
    </style>
    <script>
      if ("serviceWorker" in navigator && import.meta.env.PROD) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/service-worker.js").catch(() => undefined);
        });
      }
    </script>
    <!--
      Vercel Web Analytics + Speed Insights + 연락 클릭 추적.
      SPA(main.tsx)는 <Analytics/>를 React로 마운트하지만, Astro 빌드는 main.tsx를
      거치지 않으므로(정적 페이지 + [...all] catch-all 모두) 여기서 vanilla로 주입해
      모든 경로를 커버한다. 익명·쿠키리스(동의 배너 불필요).
    -->
    <script>
      import { inject } from "@vercel/analytics";
      import { injectSpeedInsights } from "@vercel/speed-insights";
      import { initContactTracking } from "../lib/analytics";
      inject();
      injectSpeedInsights();
      initContactTracking();
    </script>
  </body>
</html>
